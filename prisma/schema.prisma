// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProductNormalized {
  id                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_system                String                 @default("PROSCAI")
  source_country_code          String                 @default("01") @db.Char(2)
  source_icod                  String
  source_ean                   String
  source_description1          String?
  source_description2          String?
  source_description           String?
  raw_fam2                     String?
  raw_fam3                     String?
  raw_fam4                     String?
  raw_fam5                     String?
  raw_fam7                     String?
  raw_fam8                     String?
  raw_famc                     String?
  raw_unidad                   String?
  detection_bucket             String
  detection_source             String
  detection_first_word         String?
  detection_first_word_product String?
  detection_confidence         Decimal?               @db.Decimal(5, 2)
  detection_notes              String?
  normalized_product           String
  normalized_category          String?
  normalized_subcategory       String?
  normalized_material          String?
  normalized_tipo              String?
  normalized_subtipo           String?
  normalized_diameter          String?
  normalized_ced               String?
  normalized_costura           String?
  normalized_termino           String?
  normalized_acabado           String?
  normalized_radio             String?
  normalized_angulo            String?
  normalized_presion           String?
  normalized_grado             String?
  normalized_figura            String?
  visual_material              String?
  visual_color                 String?
  visual_finish                String?
  visual_shape                 String?
  visual_connection_type       String?
  visual_special_features      String?
  image_prompt                 String?
  image_negative_prompt        String?
  technical_summary            String?
  normalized_norm              String?
  normalized_coating           String?
  normalized_length            String?
  display_name                 String?
  display_description          String?
  search_text                  String?
  is_active                    Boolean                @default(true)
  is_searchable                Boolean                @default(true)
  requires_manual_review       Boolean                @default(false)
  manual_review_reason         String?
  pinecone_namespace           String?
  pinecone_vector_id           String?
  pinecone_last_upsert_at      DateTime?              @db.Timestamptz
  erp_last_seen_at             DateTime?              @db.Timestamptz
  normalized_at                DateTime?              @db.Timestamptz
  created_at                   DateTime               @default(now()) @db.Timestamptz
  updated_at                   DateTime               @updatedAt @db.Timestamptz
  images                       ProductImage[]
  technical_specs              ProductTechnicalSpec[]

  @@unique([source_system, source_icod], map: "uq_products_normalized_source")
  @@index([source_ean], map: "idx_products_normalized_ean")
  @@index([source_icod], map: "idx_products_normalized_source_icod")
  @@index([detection_bucket], map: "idx_products_normalized_bucket")
  @@index([normalized_product], map: "idx_products_normalized_product")
  @@index([normalized_category, normalized_subcategory], map: "idx_products_normalized_category")
  @@index([normalized_material], map: "idx_products_normalized_material")
  @@index([normalized_diameter], map: "idx_products_normalized_diameter")
  @@index([is_active, is_searchable], map: "idx_products_normalized_active")
  @@index([requires_manual_review], map: "idx_products_normalized_review")
  @@index([pinecone_vector_id], map: "idx_products_normalized_pinecone")
  @@map("products_normalized")
}

model ProductMissingEan {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_system        String   @default("PROSCAI")
  source_country_code  String   @default("01") @db.Char(2)
  branch_code          String?  @db.Char(2)
  source_icod          String
  source_description   String?
  detection_bucket     String?
  detection_source     String?
  detection_first_word String?
  normalized_product   String?
  normalized_category  String?
  normalized_material  String?
  normalized_diameter  String?
  normalized_ced       String?
  normalized_costura   String?
  normalized_radio     String?
  normalized_angulo    String?
  manual_review_reason String?
  first_seen_at        DateTime @default(now()) @db.Timestamptz
  last_seen_at         DateTime @default(now()) @db.Timestamptz
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @updatedAt @db.Timestamptz

  @@unique([source_system, source_icod], map: "uq_products_missing_ean_source")
  @@index([branch_code], map: "idx_products_missing_ean_branch_code")
  @@index([detection_bucket], map: "idx_products_missing_ean_bucket")
  @@index([normalized_product], map: "idx_products_missing_ean_product")
  @@map("products_missing_ean")
}

model ProductTechnicalSpec {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_normalized_id String            @db.Uuid
  label                 String
  value                 String
  standard              String?
  sort_order            Int               @default(0)
  created_at            DateTime          @default(now()) @db.Timestamptz
  updated_at            DateTime          @updatedAt @db.Timestamptz
  product               ProductNormalized @relation(fields: [product_normalized_id], references: [id], onDelete: Cascade)

  @@index([product_normalized_id], map: "idx_product_technical_specs_product_id")
  @@index([product_normalized_id, sort_order], map: "idx_product_technical_specs_sort")
  @@map("product_technical_specs")
}

model ProductImage {
  id                    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_normalized_id String  @db.Uuid
  image_type            String  @default("PRIMARY")
  generation_status     String  @default("PENDING")
  storage_provider      String?
  storage_url           String?
  file_name             String?
  mime_type             String?
  alt_text              String?
  sort_order            Int     @default(1)

  prompt           String?
  negative_prompt  String?
  generation_model String?
  background       String?
  angle            String?
  width            Int?
  height           Int?
  is_primary       Boolean           @default(false)
  created_at       DateTime          @default(now()) @db.Timestamptz
  updated_at       DateTime          @updatedAt @db.Timestamptz
  product          ProductNormalized @relation(fields: [product_normalized_id], references: [id], onDelete: Cascade)

  @@unique([product_normalized_id, sort_order], map: "uq_product_images_product_sort_order")
  @@index([product_normalized_id], map: "idx_product_images_product_id")
  @@index([generation_status], map: "idx_product_images_status")
  @@index([is_primary], map: "idx_product_images_primary")
  @@map("product_images")
}
