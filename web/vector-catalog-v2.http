@baseUrl = http://localhost:5500

### Semantic search: steel pipe without exact filters
POST {{baseUrl}}/api/vector-catalog/search
Content-Type: application/json

{
  "query": "TUBO DE ACERO AL CARBON CON COSTURA, CEDULA 10, 4 pulgadas metros",
  "branchCode": "01",
  "topK": 5,
  "candidateTopK": 40
}

### Semantic search: exact technical filters
POST {{baseUrl}}/api/vector-catalog/search
Content-Type: application/json

{
  "query": "tubo de acero para conduccion de media pulgada",
  "topK": 10,
  "filters": {
    "material": "acero al carbon",
    "diameter": "1/2",
    "ced": "40",
    "costura": "con costura"
  }
}

### Semantic search: carbon steel pipe with schedule 40
POST {{baseUrl}}/api/vector-catalog/search
Content-Type: application/json

{
  "query": "tubo negro cedula 40 con costura de seis pulgadas",
  "topK": 5,
  "candidateTopK": 40
}

